# Copy this file to `.env` and fill in real values. Never commit the
# real `.env` file -- it is excluded via .gitignore.

# Required by training/config.py + training/llm_client.py (LLM-backed
# dataset generation/labeling pipeline only; not required to run the
# API server or inference pipeline in api/, engines/, inference/).
OPENROUTER_API_KEY=replace-with-your-own-key
OPENROUTER_MODEL=google/gemini-3.5-flash

# Optional: enable API-key authentication on the Transaction
# Authentication Engine's /authenticate endpoint (see api/server.py).
# If unset, the endpoint is unauthenticated -- acceptable for local
# development only. Set this before exposing the service beyond a
# fully trusted, isolated environment.
# TRANSACTION_ENGINE_API_KEY=replace-with-a-long-random-value
