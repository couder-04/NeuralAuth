# ==========================================================
# Secrets -- never commit these.
# ==========================================================
.env
.env.*
!.env.example

# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ==========================================================
# Virtual environments
# ==========================================================
.venv/
venv/
env/

# ==========================================================
# Test / tooling caches
# ==========================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ==========================================================
# Model artifacts / large binaries / generated outputs
#
# Trained model artifacts are large, environment-specific binary
# blobs (checkpoints, encoders, scalers) that don't belong in git
# history. They should be published via a model registry / release
# artifact / LFS instead. See training/models/ and inference/predictor.py
# for what's expected to exist on disk at runtime.
# ==========================================================
outputs/
training/outputs/
*.pth
*.pt
*.onnx
*.onnx.data
*.pkl

# ==========================================================
# OS / editor cruft
# ==========================================================
.DS_Store
.idea/
.vscode/
.zshrc